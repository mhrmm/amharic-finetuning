{
    "model_dir": "experiments/en-am-nllb-1.3B-lora",
    "finetuning_parameters": {
        "base_model": "facebook/nllb-200-distilled-1.3B",
        "init_w_pretrained_weights": true,
        "freeze_encoder": false,
        "freeze_decoder": false,
        "report_every": 200,
        "validate_every": 200,
        "batch_size": 8,
        "eval_batch_size": 8,
        "src_pad_id": 0,
        "tgt_pad_id": -100,
        "num_steps": 6000,
        "use_lora": true,
        "lora_r": 8,
        "lora_alpha": 16,
        "lora_dropout": 0.05,
        "lora_target_modules": [
            "q_proj",
            "k_proj",
            "v_proj",
            "out_proj"
        ]
    },
    "tokenizers": {
        "nllb": {
            "type": "sentencepiece",
            "model": "/mnt/storage/models/nllb-200/sentencepiece.bpe.model",
            "max_length": 192,
            "vocab_offset": 1,
            "special_tokens": {
                "<pad>": 1,
                "</s>": 2,
                "eng_Latn": 256047,
                "amh_Ethi": 256009
            }
        }
    },
    "corpora": {
        "wmt-en": {
            "lang_code": "eng_Latn",
            "train": "/mnt/storage/data/am-en/afridoc/health/train.en",
            "dev": "/mnt/storage/data/am-en/afridoc/health/validation.en",
            "test": "/mnt/storage/data/am-en/afridoc/health/validation.en",
            "encipherment": "0",
            "tokenizer": "nllb"
        },
        "wmt-am": {
            "lang_code": "amh_Ethi",
            "train": "/mnt/storage/data/am-en/afridoc/health/train.am",
            "dev": "/mnt/storage/data/am-en/afridoc/health/validation.am",
            "test": "/mnt/storage/data/am-en/afridoc/health/validation.am",
            "encipherment": "0",
            "tokenizer": "nllb"
        }
    },
    "bitexts": [
        {
            "src": "wmt-en",
            "tgt": "wmt-am"
        }
    ]
}